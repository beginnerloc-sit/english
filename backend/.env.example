# Copy to .env and fill in. The .env file is server-only — never ship to the browser.

# Required for live lesson generation and realtime voice.
# If omitted, the app still runs: lesson generation uses a deterministic offline
# fallback and the realtime-token endpoint returns 503.
OPENAI_API_KEY=sk-...

# Model IDs change frequently — verify current names against OpenAI docs at build time.
OPENAI_TEXT_MODEL=gpt-4o-mini
# Optional. Leave unset for gpt-5.x models (they only allow the default). Set a
# value (e.g. 0.7) only on models that support custom temperature.
# OPENAI_TEMPERATURE=0.7
# Realtime voice (per current voice-agents docs): gpt-realtime-2 is the voice
# model; gpt-realtime-whisper handles streaming transcription.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=alloy
OPENAI_TRANSCRIBE_MODEL=gpt-realtime-whisper
# Reading voice for dialogue/word playback. Voices: alloy, echo, fable, onyx,
# nova, shimmer (verify current options in the OpenAI docs).
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova

# How many of the most-frequent NGSL-Spoken words to seed as "known" on first
# ingest, so the first lessons have enough vocabulary to be generated.
BOOTSTRAP_KNOWN_COUNT=100

# How many new target words to introduce per daily lesson (README: 6-8).
TARGETS_PER_LESSON=6

# Profiler coverage threshold (%). Generated dialogue below this is regenerated.
COVERAGE_THRESHOLD=95
